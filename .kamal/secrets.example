# Kamal deployment secrets
# Copy this to .kamal/secrets and fill in your values
# DO NOT commit the actual secrets file

# GitHub Container Registry credentials
KAMAL_REGISTRY_USERNAME=your-github-username
KAMAL_REGISTRY_PASSWORD=your-github-personal-access-token

# Server configuration
DEPLOY_HOST=your-server-ip
DEPLOY_DOMAIN=your-domain.com
LETSENCRYPT_EMAIL=your-email@example.com

# Application secret (generate with: openssl rand -hex 64)
SECRET_KEY_BASE=your-secret-key-base
