<h2><%= t('import') %></h2>
<h3><%= t('import_from_wordpress') %></h3>
<form action="<%= url('/admin/import') %>" method="post" enctype="multipart/form-data">
  <p>
    <label for="import_file"><%= t('import_file') %></label>
    <br>
    <input type="file" id="import_file" name="import[file]" value="">
  </p>
  <p>
    <input type="submit" value="<%= t('import_from_wordpress') %>">
  </p>
</form>
